# Public — Mapbox (https://account.mapbox.com/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Presets: streets-v12 (default), outdoors-v12, light-v11, dark-v11, standard
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
NEXT_PUBLIC_SITE_URL=https://jm.kartersanamo.com

# Portal database (MySQL on this server — same URL for dev and Docker host networking)
DATABASE_URL=mysql://root:YOUR_PASSWORD@127.0.0.1:3306/jm_rentals_portal

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://jm.kartersanamo.com

# Initial admin accounts (comma-separated emails, one shared temp password)
ADMIN_SEED_EMAILS=you@example.com,admin2@example.com,admin3@example.com
ADMIN_SEED_PASSWORD=

# Mailgun (https://app.mailgun.com/)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=J&M Rentals <noreply@mg.yourdomain.com>
# Webhook signing key (Mailgun → Sending → Webhooks) for inbound reply verification
MAILGUN_WEBHOOK_SIGNING_KEY=
# Fallback inbox if no staff/admin has Website contact form notifications enabled
CONTACT_TO_EMAIL=owner@example.com

# Optional
CONTACT_RATE_LIMIT_PER_HOUR=5

# Stripe (https://dashboard.stripe.com/)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Uploaded portal documents (lease PDFs, receipts, etc.)
UPLOAD_DIR=./data/uploads

# Public — Mapbox (https://account.mapbox.com/)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
# Presets: streets-v12 (default), outdoors-v12, light-v11, dark-v11, standard
NEXT_PUBLIC_MAPBOX_STYLE=mapbox://styles/mapbox/streets-v12
NEXT_PUBLIC_SITE_URL=https://jm.kartersanamo.com

# Portal database (MySQL on your server)
# Local dev: mysql://jm_portal:PASSWORD@localhost:3306/jm_rentals_portal
# Docker:   mysql://jm_portal:PASSWORD@host.docker.internal:3306/jm_rentals_portal
DATABASE_URL=

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://jm.kartersanamo.com

# Initial admin accounts (comma-separated emails, one shared temp password)
ADMIN_SEED_EMAILS=you@example.com,admin2@example.com,admin3@example.com
ADMIN_SEED_PASSWORD=

# Mailgun (https://app.mailgun.com/)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=J&M Rentals <noreply@mg.yourdomain.com>
CONTACT_TO_EMAIL=owner@example.com

# Optional
CONTACT_RATE_LIMIT_PER_HOUR=5

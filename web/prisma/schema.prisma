generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  STAFF
  RESIDENT
  GUEST
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum LeaseStatus {
  PENDING
  ACTIVE
  ENDED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  DENIED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         UserRole   @default(GUEST)
  firstName    String
  lastName     String
  phone        String?
  status       UserStatus @default(ACTIVE)
  guestNotes   String?    @db.Text
  mustChangePassword Boolean @default(false)
  emailVerifiedAt    DateTime?
  emailVerifyCodeHash String?
  emailVerifyExpires  DateTime?
  emailNotifications  Json?
  createdById  String?
  createdBy    User?      @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers User[]     @relation("UserCreatedBy")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  accounts         Account[]
  sessions         Session[]
  applications     Application[]
  leases           Lease[]              @relation("ResidentLeases")
  maintenanceRequests MaintenanceRequest[]
  paymentRecords   PaymentRecord[]
  documents        Document[]
  residentProfile  ResidentProfile?
  announcements    Announcement[]
  messageThreads   MessageThread[]      @relation("ThreadParticipant")
  sentMessages     Message[]
  auditLogs        AuditLog[]           @relation("AuditActor")

  @@index([role])
  @@index([status])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Unit {
  id          String     @id @default(cuid())
  name        String
  beds        String
  baths       String
  description String     @db.Text
  monthlyRent Decimal    @db.Decimal(10, 2)
  status      UnitStatus @default(AVAILABLE)
  address     String?
  imageUrl    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  leases       Lease[]
  applications Application[]
  documents    Document[]
  announcements Announcement[]
}

model Lease {
  id          String      @id @default(cuid())
  residentId  String
  unitId      String
  startDate   DateTime
  endDate     DateTime?
  monthlyRent Decimal     @db.Decimal(10, 2)
  status      LeaseStatus @default(PENDING)
  houseRules  String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  resident User @relation("ResidentLeases", fields: [residentId], references: [id], onDelete: Cascade)
  unit     Unit @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([residentId])
  @@index([unitId])
  @@index([status])
}

model Application {
  id              String            @id @default(cuid())
  guestId         String
  desiredUnitId   String?
  moveInDate      DateTime?
  employmentInfo  String?           @db.Text
  employmentDetails Json?
  additionalNotes String?           @db.Text
  status          ApplicationStatus @default(SUBMITTED)
  reviewNotes     String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  guest       User  @relation(fields: [guestId], references: [id], onDelete: Cascade)
  desiredUnit Unit? @relation(fields: [desiredUnitId], references: [id], onDelete: SetNull)

  @@index([guestId])
  @@index([status])
}

model MaintenanceRequest {
  id          String              @id @default(cuid())
  residentId  String
  title       String
  description String              @db.Text
  priority    MaintenancePriority @default(MEDIUM)
  status      MaintenanceStatus   @default(OPEN)
  staffNotes  String?             @db.Text
  photoPath   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  resident User @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@index([status])
}

model PaymentRecord {
  id              String    @id @default(cuid())
  residentId      String
  amount          Decimal   @db.Decimal(10, 2)
  dueDate         DateTime
  paidAt          DateTime?
  description     String
  stripePaymentId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  resident User @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
}

model Document {
  id         String   @id @default(cuid())
  title      String
  filePath   String
  residentId String?
  unitId     String?
  isGlobal   Boolean  @default(false)
  createdAt  DateTime @default(now())

  resident User? @relation(fields: [residentId], references: [id], onDelete: Cascade)
  unit     Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  authorId  String
  unitId    String?
  createdAt DateTime @default(now())

  author User  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  unit   Unit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
}

model ResidentProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  emergencyName     String?
  emergencyPhone    String?
  vehicles          String?  @db.Text
  checklistProgress Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortalSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String @db.Text
}

model MessageThread {
  id             String   @id @default(cuid())
  participantId  String
  subject        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participant User      @relation("ThreadParticipant", fields: [participantId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([participantId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  senderId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String?
  targetId   String?
  details    String?  @db.Text
  createdAt  DateTime @default(now())

  actor User @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([createdAt])
}
